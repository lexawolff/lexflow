generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//
// ENUMS
//

enum TaskType {
  PRAZO_PROCESSUAL
  PRORROGACAO_BENEFICIO
  ATENDIMENTO
  AUDIENCIA
  PERICIA
  DOCUMENTO_PENDENTE
  CONTATO_CLIENTE
  RPV
  OUTRO
}

enum UserRole {
  OWNER
  ADMIN
  LAWYER
  INTERN
  FINANCIAL
  VIEWER
}

enum PracticeArea {
  PREVIDENCIARIO
  CIVEL
  FAMILIA
  TRABALHISTA
  CONSUMIDOR
  ADMINISTRATIVO
  TRIBUTARIO
  EMPRESARIAL
  CRIMINAL
  OUTRO
}

enum CaseStatus {
  ATENDIMENTO_INICIAL
  DOCUMENTACAO_PENDENTE
  ADMINISTRATIVO
  INICIAL_EM_ELABORACAO
  PROTOCOLADO
  AGUARDANDO_PERICIA
  AGUARDANDO_SENTENCA
  RECURSO
  CUMPRIMENTO_SENTENCA
  RPV_EXPEDIDA
  RPV_PAGA
  ENCERRADO
}

enum FinancialStatus {
  PENDENTE
  PAGO
  ATRASADO
  PARCIAL
  CANCELADO
}

enum RpvStatus {
  AGUARDANDO_EXPEDICAO
  EXPEDIDA
  AUTUADA
  LIBERADA
  PAGA
  CANCELADA
}

enum TaskStatus {
  PENDENTE
  EM_ANDAMENTO
  CONCLUIDA
  CANCELADA
  ATRASADA
}

enum ExtraServiceStatus {
  A_RECEBER
  RECEBIDO
  CANCELADO
}

enum DocumentCategory {
  RG
  CPF
  CNIS
  CTPS
  COMPROVANTE_RESIDENCIA
  LAUDO
  EXAME
  RECEITA
  ATESTADO
  CONTRATO
  PROCURACAO
  PETICAO
  SENTENCA
  ACORDAO
  OUTRO
}

enum ReceivableType {
  HONORARIO_CONTRATUAL
  HONORARIO_SUCUMBENCIAL
  RPV
  ACORDO
  CONSULTA
  SERVICO_EXTRA
  OUTRO
}

enum PayableCategory {
  ALUGUEL
  SALARIO
  IMPOSTO
  SOFTWARE
  MARKETING
  MATERIAL_ESCRITORIO
  CUSTAS
  OUTRO
}

//
// USER
//

model User {
  id       String  @id @default(uuid())
  name     String
  email    String  @unique
  imageUrl String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships Membership[]
}

//
// WORKSPACE
//

model Workspace {
  id String @id @default(uuid())

  name String
  slug String @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members Membership[]

  clients Client[]
  cases   Case[]

  payables    Payable[]
  receivables Receivable[]
  rpvs        Rpv[]
  tasks       Task[]

  extraServices ExtraService[]

  documents Document[]

  clientEvents ClientEvent[]
  caseEvents   CaseEvent[]
}

//
// MEMBERSHIP
//

model Membership {
  id String @id @default(uuid())

  userId      String
  workspaceId String

  role UserRole @default(OWNER)

  createdAt DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@index([userId])
  @@index([workspaceId])
}

//
model Client {
  id          String @id @default(uuid())
  workspaceId String

  // ==========================
  // Dados pessoais
  // ==========================

  name String

  cpf String?
  rg  String?

  birthDate DateTime?

  motherName String?
  fatherName String?

  gender        String?
  maritalStatus String?

  nationality String?
  education   String?

  profession String?
  income     Float?

  // ==========================
  // Contato
  // ==========================

  phone    String?
  whatsapp String?
  email    String?

  // ==========================
  // Endereço
  // ==========================

  cep           String?
  address       String?
  addressNumber String?
  complement    String?
  neighborhood  String?
  city          String?
  state         String?

  // ==========================
  // Previdenciário
  // ==========================

  pis String?

  // ==========================
  // Gov.br
  // ==========================

  govLogin             String?
  govPasswordEncrypted String? @db.Text

  // ==========================
  // Observações
  // ==========================

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  cases       Case[]
  documents   Document[]
  receivables Receivable[]
  events      ClientEvent[]
  tasks       Task[]

  @@index([workspaceId])
  @@index([name])
  @@index([cpf])
}

//
// CASE
//

model Case {
  id String @id @default(uuid())

  workspaceId String
  clientId    String

  title String

  practiceArea PracticeArea

  subject String?

  number String?

  court     String?
  courtUnit String?

  opposingParty String?

  caseLink String?

  value Decimal?

  status CaseStatus @default(ATENDIMENTO_INICIAL)

  protocolDate DateTime?
  nextDeadline DateTime?

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  documents   Document[]
  receivables Receivable[]
  rpvs        Rpv[]
  events      CaseEvent[]
  tasks       Task[]

  @@index([workspaceId])
  @@index([clientId])
  @@index([number])
  @@index([status])
  @@index([practiceArea])
}

//
// PAYABLE
//

model Payable {
  id String @id @default(uuid())

  workspaceId String

  description String

  category PayableCategory @default(OUTRO)

  amount Decimal

  dueDate DateTime

  paidAt DateTime?

  status FinancialStatus @default(PENDENTE)

  paymentMethod String?

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([dueDate])
  @@index([status])
  @@index([category])
}

//
// RECEIVABLE
//

model Receivable {
  id String @id @default(uuid())

  workspaceId String

  clientId String

  caseId String?

  description String

  type ReceivableType @default(HONORARIO_CONTRATUAL)

  totalAmount Decimal

  paidAmount Decimal @default(0)

  dueDate DateTime?

  receivedAt DateTime?

  status FinancialStatus @default(PENDENTE)

  paymentMethod String?

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  case Case? @relation(fields: [caseId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([clientId])
  @@index([caseId])
  @@index([dueDate])
  @@index([status])
  @@index([type])
}

//
// RPV
//

model Rpv {
  id String @id @default(uuid())

  workspaceId String

  caseId String

  requisitionNumber String?

  court String?

  grossAmount Decimal

  contractualFeeRate Decimal?

  contractualFeeValue Decimal?

  sucumbencyFeeValue Decimal?

  clientNetAmount Decimal?

  expectedPaymentDate DateTime?

  paidAt DateTime?

  bank String?

  status RpvStatus @default(AGUARDANDO_EXPEDICAO)

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  case Case @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([caseId])
  @@index([expectedPaymentDate])
  @@index([status])
}

//
// TASK
//

model Task {
  id          String  @id @default(uuid())
  workspaceId String
  clientId    String?
  caseId      String?

  title       String
  description String?
  type        TaskType
  status      TaskStatus @default(PENDENTE)

  startsAt    DateTime?
  dueDate     DateTime
  completedAt DateTime?

  location      String?
  googleEventId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  client    Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)
  case      Case?     @relation(fields: [caseId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([clientId])
  @@index([caseId])
  @@index([dueDate])
  @@index([startsAt])
  @@index([status])
  @@index([type])
  @@index([googleEventId])
}

//
// EXTRA SERVICE
//

model ExtraService {
  id String @id @default(uuid())

  workspaceId String

  description String

  serviceType String

  date DateTime

  amount Decimal

  status ExtraServiceStatus @default(A_RECEBER)

  paidAt DateTime?

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([date])
  @@index([status])
}

//
// DOCUMENT
//

model Document {
  id String @id @default(uuid())

  workspaceId String

  clientId String?

  caseId String?

  name String

  category DocumentCategory?

  fileUrl String

  fileType String?

  size Int?

  uploadedBy String?

  createdAt DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  client Client? @relation(fields: [clientId], references: [id], onDelete: Cascade)

  case Case? @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([clientId])
  @@index([caseId])
  @@index([category])
}

//
// CLIENT EVENT
//

model ClientEvent {
  id String @id @default(uuid())

  workspaceId String

  clientId String

  title String

  content String?

  date DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([clientId])
}

//
// CASE EVENT
//

model CaseEvent {
  id String @id @default(uuid())

  workspaceId String

  caseId String

  title String

  content String?

  date DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  case Case @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([caseId])
}
