generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  ADMIN
  LAWYER
  INTERN
  FINANCIAL
  VIEWER
}

enum CaseStatus {
  ATENDIMENTO_INICIAL
  DOCUMENTACAO_PENDENTE
  ADMINISTRATIVO
  INICIAL_EM_ELABORACAO
  PROTOCOLADO
  AGUARDANDO_PERICIA
  AGUARDANDO_SENTENCA
  RECURSO
  CUMPRIMENTO_SENTENCA
  RPV_EXPEDIDA
  RPV_PAGA
  ENCERRADO
}

enum FinancialStatus {
  PENDENTE
  PAGO
  ATRASADO
  PARCIAL
  CANCELADO
}

enum RpvStatus {
  AGUARDANDO_EXPEDICAO
  EXPEDIDA
  AUTUADA
  LIBERADA
  PAGA
  CANCELADA
}

enum TaskStatus {
  PENDENTE
  EM_ANDAMENTO
  CONCLUIDA
  CANCELADA
  ATRASADA
}

enum TaskType {
  PRAZO_PROCESSUAL
  PRORROGACAO_BENEFICIO
  AUDIENCIA
  PERICIA
  DOCUMENTO_PENDENTE
  CONTATO_CLIENTE
  RPV
  OUTRO
}

enum ExtraServiceStatus {
  A_RECEBER
  RECEBIDO
  CANCELADO
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  imageUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships Membership[]
}

model Workspace {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members       Membership[]
  clients       Client[]
  cases         Case[]
  payables      Payable[]
  receivables   Receivable[]
  rpvs          Rpv[]
  tasks         Task[]
  extraServices ExtraService[]
  documents     Document[]
  clientEvents  ClientEvent[]
  caseEvents    CaseEvent[]
}

model Membership {
  id          String   @id @default(uuid())
  userId      String
  workspaceId String
  role        UserRole @default(OWNER)
  createdAt   DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@index([userId])
  @@index([workspaceId])
}

model Client {
  id          String @id @default(uuid())
  workspaceId String

  name       String
  cpf        String?
  rg         String?
  birthDate  DateTime?
  phone      String?
  whatsapp   String?
  email      String?
  profession String?
  income     Decimal?
  address    String?
  city       String?
  state      String?
  notes      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  cases       Case[]
  documents   Document[]
  receivables Receivable[]
  events      ClientEvent[]
  tasks       Task[]

  @@index([workspaceId])
  @@index([name])
  @@index([cpf])
}

model Case {
  id          String @id @default(uuid())
  workspaceId String
  clientId    String

  title         String
  number        String?
  court         String?
  courtUnit     String?
  subject       String?
  opposingParty String?
  caseLink      String?
  value         Decimal?
  status        CaseStatus @default(ATENDIMENTO_INICIAL)

  protocolDate DateTime?
  nextDeadline DateTime?
  notes        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  client    Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)

  documents   Document[]
  receivables Receivable[]
  rpvs        Rpv[]
  events      CaseEvent[]
  tasks       Task[]

  @@index([workspaceId])
  @@index([clientId])
  @@index([number])
  @@index([status])
}

model Payable {
  id          String @id @default(uuid())
  workspaceId String

  description   String
  category      String?
  amount        Decimal
  dueDate       DateTime
  paidAt        DateTime?
  status        FinancialStatus @default(PENDENTE)
  paymentMethod String?
  notes         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([dueDate])
  @@index([status])
}

model Receivable {
  id          String  @id @default(uuid())
  workspaceId String
  clientId    String
  caseId      String?

  description   String
  type          String?
  totalAmount   Decimal
  paidAmount    Decimal         @default(0)
  dueDate       DateTime?
  receivedAt    DateTime?
  status        FinancialStatus @default(PENDENTE)
  paymentMethod String?
  notes         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  client    Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  case      Case?     @relation(fields: [caseId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([clientId])
  @@index([caseId])
  @@index([dueDate])
  @@index([status])
}

model Rpv {
  id          String @id @default(uuid())
  workspaceId String
  caseId      String

  requisitionNumber   String?
  court               String?
  grossAmount         Decimal
  contractualFeeRate  Decimal?
  contractualFeeValue Decimal?
  sucumbencyFeeValue  Decimal?
  clientNetAmount     Decimal?
  expectedPaymentDate DateTime?
  paidAt              DateTime?
  bank                String?
  status              RpvStatus @default(AGUARDANDO_EXPEDICAO)
  notes               String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  case      Case      @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([caseId])
  @@index([expectedPaymentDate])
  @@index([status])
}

model Task {
  id          String  @id @default(uuid())
  workspaceId String
  clientId    String?
  caseId      String?

  title       String
  description String?
  type        TaskType
  status      TaskStatus @default(PENDENTE)

  startsAt    DateTime?
  dueDate     DateTime
  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  client    Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)
  case      Case?     @relation(fields: [caseId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([clientId])
  @@index([caseId])
  @@index([dueDate])
  @@index([status])
  @@index([type])
}

model ExtraService {
  id          String @id @default(uuid())
  workspaceId String

  description String
  serviceType String
  date        DateTime
  amount      Decimal
  status      ExtraServiceStatus @default(A_RECEBER)
  paidAt      DateTime?
  notes       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([date])
  @@index([status])
}

model Document {
  id          String  @id @default(uuid())
  workspaceId String
  clientId    String?
  caseId      String?

  name     String
  fileUrl  String
  fileType String?
  size     Int?

  createdAt DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  client    Client?   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  case      Case?     @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([clientId])
  @@index([caseId])
}

model ClientEvent {
  id          String @id @default(uuid())
  workspaceId String
  clientId    String

  title   String
  content String?
  date    DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  client    Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([clientId])
}

model CaseEvent {
  id          String @id @default(uuid())
  workspaceId String
  caseId      String

  title   String
  content String?
  date    DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  case      Case      @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([caseId])
}
